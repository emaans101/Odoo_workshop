<odoo>
    <record id="clinic_patient_action" model="ir.actions.act_window">
        <field name="name">Patients</field>
        <field name="res_model">clinic.patient</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="clinic_patient_view_list" model="ir.ui.view">
        <field name="name">clinic.patient.list</field>
        <field name="model">clinic.patient</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="age"/>
                <field name="gender"/>
                <field name="blood_group"/>
                <field name="phone"/>
            </list>
        </field>
    </record>

    <record id="clinic_patient_view_form" model="ir.ui.view">
        <field name="name">clinic.patient.form</field>
        <field name="model">clinic.patient</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Patient Name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="age"/>
                            <field name="gender"/>
                            <field name="blood_group"/>
                        </group>
                        <group>
                            <field name="phone"/>
                            <field name="email"/>
                            <field name="last_visit_date"/>
                        </group>
                    </group>
                    <group string="Notes">
                        <field name="notes" nolabel="1" placeholder="Additional notes..."/>
                    </group>
                    <notebook>
                        <page string="Appointments">
                            <field name="appointment_ids" readonly="1">
                                <list>
                                    <field name="date_start"/>
                                    <field name="doctor_id"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>
                        <page string="Consultations">
                            <field name="consultation_ids" readonly="1">
                                <list>
                                    <field name="date"/>
                                    <field name="doctor_id"/>
                                    <field name="diagnosis"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
</odoo>