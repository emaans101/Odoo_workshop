<odoo>
    <record id="clinic_appointment_action" model="ir.actions.act_window">
        <field name="name">Appointments</field>
        <field name="res_model">clinic.appointment</field>
        <field name="view_mode">list,form,calendar</field>
    </record>

    <record id="clinic_appointment_view_list" model="ir.ui.view">
        <field name="name">clinic.appointment.list</field>
        <field name="model">clinic.appointment</field>
        <field name="arch" type="xml">
            <list>
                <field name="date_start"/>
                <field name="patient_id"/>
                <field name="doctor_id"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="clinic_appointment_view_form" model="ir.ui.view">
        <field name="name">clinic.appointment.form</field>
        <field name="model">clinic.appointment</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="state" widget="statusbar"
                           statusbar_visible="scheduled,completed,cancelled"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="patient_id"/>
                            <field name="doctor_id"/>
                        </group>
                        <group>
                            <field name="date_start"/>
                        </group>
                    </group>
                    <group string="Reason">
                        <field name="reason" nolabel="1" placeholder="Reason for visit..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="clinic_appointment_view_calendar" model="ir.ui.view">
        <field name="name">clinic.appointment.calendar</field>
        <field name="model">clinic.appointment</field>
        <field name="arch" type="xml">
            <calendar date_start="date_start" color="doctor_id">
                <field name="patient_id"/>
                <field name="doctor_id"/>
            </calendar>
        </field>
    </record>
</odoo>