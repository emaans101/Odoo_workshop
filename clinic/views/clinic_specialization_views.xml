<odoo>
    <record id="clinic_specialization_action" model="ir.actions.act_window">
        <field name="name">Specializations</field>
        <field name="res_model">clinic.specialization</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="clinic_specialization_view_list" model="ir.ui.view">
        <field name="name">clinic.specialization.list</field>
        <field name="model">clinic.specialization</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="clinic_specialization_view_form" model="ir.ui.view">
        <field name="name">clinic.specialization.form</field>
        <field name="model">clinic.specialization</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>
                    <field name="doctor_ids">
                        <list>
                            <field name="name"/>
                            <field name="phone"/>
                            <field name="email"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
