<odoo>
    <record id="clinic_consultation_action" model="ir.actions.act_window">
        <field name="name">Consultations</field>
        <field name="res_model">clinic.consultation</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="clinic_consultation_view_list" model="ir.ui.view">
        <field name="name">clinic.consultation.list</field>
        <field name="model">clinic.consultation</field>
        <field name="arch" type="xml">
            <list decoration-success="state == 'done'">
                <field name="date"/>
                <field name="patient_id"/>
                <field name="doctor_id"/>
                <field name="diagnosis"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="clinic_consultation_view_form" model="ir.ui.view">
        <field name="name">clinic.consultation.form</field>
        <field name="model">clinic.consultation</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_done" type="object" string="Mark as Done"
                            class="btn-primary" invisible="state == 'done'"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="patient_id"/>
                            <field name="doctor_id"/>
                            <field name="date"/>
                        </group>
                        <group>
                            <field name="temperature"/>
                            <field name="blood_pressure"/>
                            <field name="weight"/>
                        </group>
                    </group>
                    <group>
                        <group string="Symptoms">
                            <field name="symptoms" nolabel="1"/>
                        </group>
                        <group string="Diagnosis">
                            <field name="diagnosis" nolabel="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Prescription">
                            <field name="prescription_line_ids">
                                <list editable="bottom">
                                    <field name="medicine_id"/>
                                    <field name="dosage"/>
                                    <field name="quantity"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notes">
                            <field name="notes" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
</odoo>
